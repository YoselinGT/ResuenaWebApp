# .env.example — Plantilla de variables de entorno de Resuena.
# Copiar a .env y completar los valores reales antes de `docker compose up -d`.
# NUNCA commitear el .env con valores reales — solo este .env.example va al repo.

# ── Entorno ────────────────────────────────────────────────────
ENVIRONMENT=development               # development | staging | production
APP_SECRET_KEY=dev-secret-key-cambiar-en-produccion-minimo-32-chars

# ── Base de datos (PostgreSQL) ─────────────────────────────────
POSTGRES_USER=portal
POSTGRES_PASSWORD=portal
POSTGRES_DB=resuena
DATABASE_URL=postgresql+asyncpg://portal:portal@postgres:5432/resuena

# ── Redis (cache / sesiones / tokens efímeros) ─────────────────
REDIS_URL=redis://redis:6379/0

# ── RabbitMQ (colas) ───────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ── Almacenamiento (abstracción StorageProvider) ───────────────
# STORAGE_PROVIDER: s3 (activo) | gcs | azure (preparados, sin cambios de código)
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=test                # 'test' en dev (LocalStack)
AWS_SECRET_ACCESS_KEY=test            # 'test' en dev (LocalStack)
AWS_REGION=us-east-1
AWS_S3_BUCKET=resuena-dev
# AWS_ENDPOINT_URL: apunta a LocalStack en dev; VACÍO en prod (usa AWS real).
AWS_ENDPOINT_URL=http://localstack:4566
# AWS_PUBLIC_ENDPOINT_URL: host alcanzable desde el navegador para firmar URLs
# presigned en dev (LocalStack expuesto en localhost). VACÍO en prod.
AWS_PUBLIC_ENDPOINT_URL=http://localhost:4566

# ── Email (dev — MailHog) ──────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=no-reply@resuena.local

# ── Pagos (Stripe — modo test en dev) ──────────────────────────
# Obtener en https://dashboard.stripe.com (claves de test sk_test_... / whsec_...)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Observabilidad (Sentry — opcional en dev) ──────────────────
SENTRY_DSN=

# ── Frontend ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
